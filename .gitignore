# Dependencies
node_modules/
.pnp
.pnp.js
.pnp.cjs

# Build
.next/
out/
build/
dist/

# Test coverage snapshots (used by test-gen workflow; never tracked)
.coverage-snapshots/

# Environment variables - NEVER commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
# env generator artifacts (secrets) — SEC-1
# Init-env now writes .env (the canonical file Docker Compose auto-reads);
# legacy .env.local.* patterns kept for developers mid-migration.
.env.tmp
.env.tmp.*
.env.bak
.env.bak-*
.env.bak.*
.env.local.tmp
.env.local.tmp.*
.env.local.bak
.env.local.bak-*
.env.local.bak.*

# Database
*.db
*.sqlite

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
*.textClipping

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Prisma
prisma/*.db
prisma/*.db-journal

# Docker volumes
postgres_data/

# Test
coverage/
e2e/.auth-state.json
e2e/playwright-report/
e2e/test-results/
test-results/
load-test/setup/.load-test-auth.json

# CLI secrets config (contains user-specific vault entry IDs)
.passwd-sso-env.json

# Secrets & Keys - NEVER commit
*.pem
*.key
*.crt
*.p12
*.pfx
master.key
encryption.key

# SAML certificates
saml/
*.cert

# Terraform
infra/terraform/.terraform/
infra/terraform/**/*.tfstate
infra/terraform/**/*.tfstate.backup
infra/terraform/envs/*/terraform.tfvars

# Extension
extension/dist/
extension/node_modules/

# Temporary docs (review notes, scratch)
docs/temp/

# Claude (allow skills, hooks, settings; ignore sessions/cache)
.claude/*
!.claude/skills/
!.claude/hooks/
!.claude/settings.json

# Refactor orchestration — per-developer stale-branch baseline
.refactor-phase-verify-baseline
