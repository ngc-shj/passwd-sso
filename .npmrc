# A04-4 / C21 era: next-auth@5.0.0-beta.31 declares
#   peerOptional @simplewebauthn/browser@^9.0.1
# next-auth/@auth/core 0.34.x version-pin both libraries to v9 internally,
# while we use @simplewebauthn/browser@^11 directly (project-owned WebAuthn
# Credentials authorize() flow that does NOT use Auth.js's WebAuthn provider —
# verified via the `Static: no-authjs-builtin-webauthn-provider` pre-pr.sh guard).
#
# npm 9+ enforces peerOptional resolution strictly under `npm ci`, refusing
# to install when our v11 conflicts with next-auth's v9 expectation, even
# though the dep is OPTIONAL. `legacy-peer-deps=true` restores the npm 8-
# style behavior where peer conflicts produce a warning instead of an error.
#
# Safety: the static guard `no-authjs-builtin-webauthn-provider` blocks any
# import of `@auth/core/providers/passkey|webauthn` (the v9-pinned code paths
# inside next-auth). So even with the conflict, our runtime never executes
# next-auth's WebAuthn code — only our own v11 surface is reachable.
legacy-peer-deps=true
