{
  "name": "passwd-sso",
  "version": "0.4.70",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --experimental-https",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check:team-auth-rls": "node scripts/checks/check-team-auth-rls.mjs",
    "check:bypass-rls": "node scripts/checks/check-bypass-rls.mjs",
    "check:crypto-domains": "node scripts/checks/check-crypto-domains.mjs",
    "check:migration-drift": "node scripts/checks/check-migration-drift.mjs",
    "check:raw-sql-usage": "node scripts/checks/check-raw-sql-usage.mjs",
    "check:ios-diag": "bash scripts/checks/check-ios-no-diagnostic-logging.sh",
    "pre-pr": "bash scripts/pre-pr.sh",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "generate:icons": "bash scripts/generate-icons.sh",
    "generate:key": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "generate:audit-anchor-signing-key": "bash scripts/generate-audit-anchor-signing-key.sh",
    "generate:audit-anchor-tag-secret": "bash scripts/generate-audit-anchor-tag-secret.sh",
    "generate:team-key-fixture": "tsx scripts/generate-team-key-fixture.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "licenses:check": "node scripts/checks/check-licenses.mjs --name app --lockfile package-lock.json",
    "licenses:check:strict": "node scripts/checks/check-licenses.mjs --name app --lockfile package-lock.json --strict",
    "licenses:check:ext": "node scripts/checks/check-licenses.mjs --name extension --lockfile extension/package-lock.json",
    "licenses:check:ext:strict": "node scripts/checks/check-licenses.mjs --name extension --lockfile extension/package-lock.json --strict",
    "licenses:check:cli": "node scripts/checks/check-licenses.mjs --name cli --lockfile cli/package-lock.json",
    "licenses:check:cli:strict": "node scripts/checks/check-licenses.mjs --name cli --lockfile cli/package-lock.json --strict",
    "test:load:seed": "node load-test/setup/seed-load-test-users.mjs",
    "test:load:cleanup": "node load-test/setup/seed-load-test-users.mjs --cleanup",
    "test:load:smoke": "node load-test/setup/seed-load-test-users.mjs --smoke",
    "test:load": "k6 run load-test/scenarios/mixed-workload.js",
    "test:load:health": "k6 run load-test/scenarios/health.js",
    "scim:smoke": "bash scripts/scim-smoke.sh",
    "test:cli": "cd cli && npm test",
    "version:bump": "bash scripts/bump-version.sh",
    "worker:audit-outbox": "tsx scripts/audit-outbox-worker.ts",
    "worker:retention-gc": "tsx scripts/retention-gc-worker.ts",
    "worker:audit-chain-verify": "tsx scripts/audit-chain-verify-worker.ts",
    "migrate:account-tokens": "tsx scripts/migrate-account-tokens-to-encrypted.ts",
    "generate:env-example": "tsx scripts/generate-env-example.ts",
    "check:env-docs": "tsx scripts/check-env-docs.ts",
    "generate:security-matrices": "tsx scripts/generate-security-matrices.ts",
    "check:security-matrices": "bash scripts/checks/check-security-matrices.sh",
    "init:env": "tsx scripts/init-env.ts",
    "docker:up": "docker compose -f docker-compose.yml -f docker-compose.override.yml up",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.override.yml down"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.67.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@swc/helpers": "0.5.23",
    "bowser": "^2.14.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.4",
    "file-type": "^22.0.1",
    "hash-wasm": "4.12.0",
    "ioredis": "^5.11.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.3",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.1",
    "otpauth": "^9.5.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "radix-ui": "^1.6.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.82.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.17.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "undici": "^7.28.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@noble/hashes": "^2.2.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "prisma": "^7.9.0",
    "shadcn": "^4.13.1",
    "tailwindcss": "^4.1.18",
    "ts-morph": "^28.0.0",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "qs": "6.15.2",
    "hono": "4.12.25",
    "@hono/node-server": "1.19.13",
    "lodash": "^4.18.1",
    "cross-spawn": "7.0.6",
    "@babel/core": "^7.29.6",
    "nodemailer": "^9.0.1",
    "effect": ">=3.20.0",
    "postcss": ">=8.5.10",
    "brace-expansion@1": "^1.1.16",
    "brace-expansion@2": "^2.1.2",
    "brace-expansion@>=5.0.0 <5.0.7": "^5.0.7",
    "js-yaml@>=4.0.0 <4.3.0": "^4.3.0",
    "esbuild": ">=0.28.1"
  }
}
