{
  "name": "passwd-sso-cli",
  "version": "0.4.70",
  "description": "CLI for passwd-sso password manager",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ngc-shj/passwd-sso.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/ngc-shj/passwd-sso/tree/main/cli",
  "keywords": [
    "password-manager",
    "cli",
    "sso",
    "vault",
    "ssh-agent"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "passwd-sso": "./dist/index.js"
  },
  "publishConfig": {
    "provenance": true
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bcrypt-pbkdf": "^1.0.2",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "clipboardy": "^5.3.1",
    "commander": "^15.0.0",
    "inquirer": "^14.0.2",
    "otpauth": "^9.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": ">=8.5.10",
    "esbuild": ">=0.28.1"
  }
}
