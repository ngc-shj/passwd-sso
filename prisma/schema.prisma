generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js Required Models ────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  tenantId          String  @map("tenant_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([provider, providerAccountId])
  @@index([tenantId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  tenantId     String   @map("tenant_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(512)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([userId, expires])
  @@index([tenantId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Application Models ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Vault (E2E encryption) fields
  vaultSetupAt             DateTime? @map("vault_setup_at")
  accountSalt              String?   @map("account_salt") @db.VarChar(64)
  encryptedSecretKey       String?   @map("encrypted_secret_key") @db.Text
  secretKeyIv              String?   @map("secret_key_iv") @db.VarChar(24)
  secretKeyAuthTag         String?   @map("secret_key_auth_tag") @db.VarChar(32)
  masterPasswordServerHash String?   @map("master_password_server_hash") @db.Text
  masterPasswordServerSalt String?   @map("master_password_server_salt") @db.VarChar(64)
  keyVersion               Int       @default(0) @map("key_version")

  // KDF metadata — per-user params for future algorithm migration
  kdfType        Int @default(0) @map("kdf_type")
  // 0 = PBKDF2-SHA256 (only value accepted in P0)
  kdfIterations  Int @default(600000) @map("kdf_iterations")
  kdfMemory      Int? @map("kdf_memory")
  // Argon2id memory cost in KiB (future, P2)
  kdfParallelism Int? @map("kdf_parallelism")
  // Argon2id parallelism (future, P2)

  // HMAC(pepper, SHA-256(PBKDF2(passphrase, verifierSalt))) — 本人確認用、暗号鍵導出には使わない
  passphraseVerifierHmac    String? @map("passphrase_verifier_hmac") @db.VarChar(64)
  passphraseVerifierVersion Int     @default(1) @map("passphrase_verifier_version")

  // Recovery Key (client-side generated, server stores encrypted blob + verifier)
  recoveryEncryptedSecretKey String?   @map("recovery_encrypted_secret_key") @db.Text
  recoverySecretKeyIv        String?   @map("recovery_secret_key_iv") @db.VarChar(24)
  recoverySecretKeyAuthTag   String?   @map("recovery_secret_key_auth_tag") @db.VarChar(32)
  recoveryHkdfSalt           String?   @map("recovery_hkdf_salt") @db.VarChar(64)
  recoveryVerifierHmac       String?   @map("recovery_verifier_hmac") @db.VarChar(64)
  recoveryKeySetAt           DateTime? @map("recovery_key_set_at")

  // User preference
  locale String? @db.VarChar(5)

  // Account lockout
  failedUnlockAttempts Int       @default(0) @map("failed_unlock_attempts")
  lastFailedUnlockAt   DateTime? @map("last_failed_unlock_at")
  accountLockedUntil   DateTime? @map("account_locked_until")

  accounts  Account[]
  sessions  Session[]
  passwords PasswordEntry[]
  tags      Tag[]
  vaultKeys VaultKey[]

  // Team relations
  teamMemberships       TeamMember[]
  tenantMemberships     TenantMember[]
  teamInvitations       TeamInvitation[]
  createdTeamPasswords  TeamPasswordEntry[]    @relation("teamPasswordCreator")
  updatedTeamPasswords  TeamPasswordEntry[]    @relation("teamPasswordUpdater")
  teamPasswordFavorites TeamPasswordFavorite[]
  auditLogs             AuditLog[]
  passwordShares        PasswordShare[]
  attachments           Attachment[]

  // ECDH key pair for team E2E encryption
  ecdhPublicKey           String? @map("ecdh_public_key") @db.Text
  encryptedEcdhPrivateKey String? @map("encrypted_ecdh_private_key") @db.Text
  ecdhPrivateKeyIv        String? @map("ecdh_private_key_iv") @db.VarChar(24)
  ecdhPrivateKeyAuthTag   String? @map("ecdh_private_key_auth_tag") @db.VarChar(32)

  // Emergency Access relations
  emergencyGrantsAsOwner   EmergencyAccessGrant[] @relation("emergencyGrantsAsOwner")
  emergencyGrantsAsGrantee EmergencyAccessGrant[] @relation("emergencyGrantsAsGrantee")

  // Extension tokens
  extensionTokens ExtensionToken[]

  // Admin vault resets
  adminVaultResetsAsTarget    AdminVaultReset[] @relation("adminVaultResetTarget")
  adminVaultResetsAsInitiator AdminVaultReset[] @relation("adminVaultResetInitiator")

  // Travel Mode
  travelModeActive      Boolean   @default(false) @map("travel_mode_active")
  travelModeActivatedAt DateTime? @map("travel_mode_activated_at")

  // SCIM tokens
  createdScimTokens ScimToken[]

  // API keys & WebAuthn
  apiKeys             ApiKey[]
  webauthnCredentials WebAuthnCredential[]

  // Folder relations
  folders               Folder[]
  teamPasswordHistories TeamPasswordEntryHistory[]
  teamMemberKeys        TeamMemberKey[]
  notifications         Notification[]
  breakGlassRequested PersonalLogAccessGrant[] @relation("BreakGlassRequester")
  breakGlassTargeted  PersonalLogAccessGrant[] @relation("BreakGlassTarget")
  tenant                Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@map("users")
}

model ExtensionToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tenantId   String    @map("tenant_id")
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  scope      String    @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  revokedAt  DateTime? @map("revoked_at")
  lastUsedAt DateTime? @map("last_used_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("extension_tokens")
}

model ScimToken {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  tokenHash   String    @unique @map("token_hash") @db.VarChar(64)
  description String?   @db.VarChar(255)
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  revokedAt   DateTime? @map("revoked_at")
  lastUsedAt  DateTime? @map("last_used_at")
  createdById String?   @map("created_by_id")

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdBy User?  @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, revokedAt])
  @@map("scim_tokens")
}

model ScimExternalMapping {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  externalId   String   @map("external_id")
  resourceType String   @map("resource_type") @db.VarChar(20)
  internalId   String   @map("internal_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, externalId, resourceType])
  @@unique([tenantId, internalId, resourceType])
  @@index([tenantId, resourceType])
  @@map("scim_external_mappings")
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String?
  parentId  String?  @map("parent_id")
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent    Tag?            @relation("TagHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Tag[]           @relation("TagHierarchy")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  passwords PasswordEntry[]

  @@unique([name, parentId, userId])
  @@index([tenantId])
  @@map("tags")
}

model VaultKey {
  id                     String   @id @default(cuid())
  userId                 String   @map("user_id")
  tenantId               String   @map("tenant_id")
  version                Int
  verificationCiphertext String   @map("verification_ciphertext") @db.Text
  verificationIv         String   @map("verification_iv") @db.VarChar(24)
  verificationAuthTag    String   @map("verification_auth_tag") @db.VarChar(32)
  createdAt              DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([userId, version])
  @@index([tenantId])
  @@map("vault_keys")
}

model PasswordEntry {
  id String @id @default(cuid())

  // E2E encrypted fields (all data encrypted client-side)
  encryptedBlob     String    @map("encrypted_blob") @db.Text
  blobIv            String    @map("blob_iv") @db.VarChar(24)
  blobAuthTag       String    @map("blob_auth_tag") @db.VarChar(32)
  encryptedOverview String    @map("encrypted_overview") @db.Text
  overviewIv        String    @map("overview_iv") @db.VarChar(24)
  overviewAuthTag   String    @map("overview_auth_tag") @db.VarChar(32)
  keyVersion        Int       @map("key_version")
  aadVersion        Int       @default(0) @map("aad_version")
  entryType         EntryType @default(LOGIN) @map("entry_type")

  // Metadata (unencrypted)
  isFavorite      Boolean   @default(false) @map("is_favorite")
  isArchived      Boolean   @default(false) @map("is_archived")
  requireReprompt Boolean   @default(false) @map("require_reprompt")
  expiresAt       DateTime? @map("expires_at")
  deletedAt       DateTime? @map("deleted_at")

  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  folderId  String?  @map("folder_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tags        Tag[]
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  folder      Folder?                @relation(fields: [folderId], references: [id], onDelete: SetNull)
  shares      PasswordShare[]        @relation("personalShares")
  attachments Attachment[]
  histories   PasswordEntryHistory[]

  @@index([userId, deletedAt, isArchived])
  @@index([tenantId])
  @@map("password_entries")
}

// ─── Team Models ────────────────────────────────────────

enum EntryType {
  LOGIN
  SECURE_NOTE
  CREDIT_CARD
  IDENTITY
  PASSKEY
  BANK_ACCOUNT
  SOFTWARE_LICENSE
  SSH_KEY
}

enum ShareType {
  ENTRY_SHARE
  TEXT
  FILE
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProvisioningSource {
  MANUAL
  SCIM
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model Team {
  id          String  @id @default(cuid())
  tenantId    String  @map("tenant_id")
  name        String
  slug        String  @unique
  description String? @db.Text

  // E2E encryption (ECDH-P256)
  teamKeyVersion Int @default(1) @map("team_key_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members              TeamMember[]
  passwords            TeamPasswordEntry[]
  tags                 TeamTag[]
  folders              TeamFolder[]
  invitations          TeamInvitation[]
  auditLogs            AuditLog[]
  memberKeys           TeamMemberKey[]
  scimGroupMappings    ScimGroupMapping[]
  policy               TeamPolicy?
  webhooks             TeamWebhook[]
  adminVaultResets     AdminVaultReset[]
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@map("teams")
}

model Tenant {
  id          String   @id @default(cuid())
  externalId  String?  @unique @map("external_id") @db.VarChar(255)
  isBootstrap Boolean  @default(false) @map("is_bootstrap")
  name        String
  slug        String   @unique
  description           String?  @db.Text
  maxConcurrentSessions    Int?     @map("max_concurrent_sessions")
  sessionIdleTimeoutMinutes Int?     @map("session_idle_timeout_minutes")
  vaultAutoLockMinutes      Int?     @map("vault_auto_lock_minutes")
  allowedCidrs              String[] @default([]) @map("allowed_cidrs")
  tailscaleEnabled          Boolean  @default(false) @map("tailscale_enabled")
  tailscaleTailnet          String?  @map("tailscale_tailnet") @db.VarChar(255)
  requireMinPinLength      Int?     @map("require_min_pin_length")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  users                      User[]
  accounts                   Account[]
  sessions                   Session[]
  extensionTokens            ExtensionToken[]
  tags                       Tag[]
  vaultKeys                  VaultKey[]
  passwordEntries            PasswordEntry[]
  teams                      Team[]
  members                    TenantMember[]
  teamMembers                TeamMember[]
  teamMemberKeys             TeamMemberKey[]
  teamPasswordEntries        TeamPasswordEntry[]
  teamTags                   TeamTag[]
  teamPasswordFavorites      TeamPasswordFavorite[]
  teamInvitations            TeamInvitation[]
  passwordShares             PasswordShare[]
  shareAccessLogs            ShareAccessLog[]
  auditLogs                  AuditLog[]
  attachments                Attachment[]
  emergencyAccessGrants      EmergencyAccessGrant[]
  folders                    Folder[]
  teamFolders                TeamFolder[]
  passwordEntryHistories     PasswordEntryHistory[]
  teamPasswordEntryHistories TeamPasswordEntryHistory[]
  emergencyAccessKeyPairs    EmergencyAccessKeyPair[]
  scimTokens                 ScimToken[]
  scimExternalMappings       ScimExternalMapping[]
  scimGroupMappings          ScimGroupMapping[]
  apiKeys                    ApiKey[]
  webauthnCredentials        WebAuthnCredential[]
  directorySyncConfigs       DirectorySyncConfig[]
  directorySyncLogs          DirectorySyncLog[]
  notifications              Notification[]
  teamPolicies               TeamPolicy[]
  teamWebhooks               TeamWebhook[]
  tenantWebhooks             TenantWebhook[]
  adminVaultResets           AdminVaultReset[]
  personalLogAccessGrants    PersonalLogAccessGrant[]

  @@map("tenants")
}

model TenantMember {
  id                 String             @id @default(cuid())
  tenantId           String             @map("tenant_id")
  userId             String             @map("user_id")
  role               TenantRole         @default(MEMBER)
  deactivatedAt      DateTime?          @map("deactivated_at")
  scimManaged        Boolean            @default(false) @map("scim_managed")
  provisioningSource ProvisioningSource @default(MANUAL) @map("provisioning_source")
  lastScimSyncedAt   DateTime?          @map("last_scim_synced_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_members")
}

model ScimGroupMapping {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  teamId          String   @map("team_id")
  externalGroupId String   @map("external_group_id")
  role            TeamRole @default(MEMBER)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalGroupId])
  @@index([tenantId])
  @@index([teamId])
  @@map("scim_group_mappings")
}

model TeamMember {
  id             String    @id @default(cuid())
  teamId         String    @map("team_id")
  userId         String    @map("user_id")
  tenantId       String    @map("tenant_id")
  role           TeamRole  @default(MEMBER)
  keyDistributed Boolean   @default(false) @map("key_distributed")
  deactivatedAt  DateTime? @map("deactivated_at")
  scimManaged    Boolean   @default(false) @map("scim_managed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([teamId, userId])
  @@index([tenantId])
  @@map("team_members")
}

model TeamMemberKey {
  id                 String   @id @default(cuid())
  teamId             String   @map("team_id")
  userId             String   @map("user_id")
  tenantId           String   @map("tenant_id")
  encryptedTeamKey   String   @map("encrypted_team_key") @db.Text
  teamKeyIv          String   @map("team_key_iv") @db.VarChar(24)
  teamKeyAuthTag     String   @map("team_key_auth_tag") @db.VarChar(32)
  ephemeralPublicKey String   @map("ephemeral_public_key") @db.Text
  hkdfSalt           String   @map("hkdf_salt") @db.VarChar(64)
  wrapVersion        Int      @default(1) @map("wrap_version")
  keyVersion         Int      @default(1) @map("key_version")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([teamId, userId, keyVersion])
  @@index([userId])
  @@index([tenantId])
  @@map("team_member_keys")
}

model TeamPasswordEntry {
  id String @id @default(cuid())

  // Server-side encrypted fields (encrypted with per-team key)
  encryptedBlob String @map("encrypted_blob") @db.Text
  blobIv        String @map("blob_iv") @db.VarChar(24)
  blobAuthTag   String @map("blob_auth_tag") @db.VarChar(32)

  encryptedOverview String    @map("encrypted_overview") @db.Text
  overviewIv        String    @map("overview_iv") @db.VarChar(24)
  overviewAuthTag   String    @map("overview_auth_tag") @db.VarChar(32)
  aadVersion        Int       @default(0) @map("aad_version")
  teamKeyVersion    Int       @default(0) @map("team_key_version")
  itemKeyVersion    Int       @default(0) @map("item_key_version")
  encryptedItemKey  String?   @map("encrypted_item_key") @db.Text
  itemKeyIv         String?   @map("item_key_iv") @db.VarChar(24)
  itemKeyAuthTag    String?   @map("item_key_auth_tag") @db.VarChar(32)
  entryType         EntryType @default(LOGIN) @map("entry_type")

  // Metadata (unencrypted)
  isArchived     Boolean   @default(false) @map("is_archived")
  requireReprompt Boolean  @default(false) @map("require_reprompt")
  expiresAt      DateTime? @map("expires_at")
  deletedAt      DateTime? @map("deleted_at")

  teamId       String  @map("team_id")
  tenantId     String  @map("tenant_id")
  createdById  String  @map("created_by_id")
  updatedById  String  @map("updated_by_id")
  teamFolderId String? @map("team_folder_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team        Team                       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tenant      Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdBy   User                       @relation("teamPasswordCreator", fields: [createdById], references: [id])
  updatedBy   User                       @relation("teamPasswordUpdater", fields: [updatedById], references: [id])
  teamFolder  TeamFolder?                @relation(fields: [teamFolderId], references: [id], onDelete: SetNull)
  tags        TeamTag[]
  favorites   TeamPasswordFavorite[]
  shares      PasswordShare[]            @relation("teamShares")
  attachments Attachment[]
  histories   TeamPasswordEntryHistory[]

  @@index([teamId, deletedAt])
  @@index([tenantId])
  @@map("team_password_entries")
}

model TeamTag {
  id       String  @id @default(cuid())
  name     String
  color    String?
  parentId String? @map("parent_id")

  teamId   String @map("team_id")
  tenantId String @map("tenant_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent    TeamTag?            @relation("TeamTagHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  TeamTag[]           @relation("TeamTagHierarchy")
  team      Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  passwords TeamPasswordEntry[]

  @@unique([name, parentId, teamId])
  @@index([tenantId])
  @@map("team_tags")
}

model TeamPasswordFavorite {
  id                  String @id @default(cuid())
  userId              String @map("user_id")
  tenantId            String @map("tenant_id")
  teamPasswordEntryId String @map("team_password_entry_id")

  createdAt DateTime @default(now()) @map("created_at")

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  teamPasswordEntry TeamPasswordEntry @relation(fields: [teamPasswordEntryId], references: [id], onDelete: Cascade)

  @@unique([userId, teamPasswordEntryId])
  @@index([tenantId])
  @@map("team_password_favorites")
}

model TeamInvitation {
  id        String           @id @default(cuid())
  teamId    String           @map("team_id")
  tenantId  String           @map("tenant_id")
  email     String
  role      TeamRole         @default(MEMBER)
  status    InvitationStatus @default(PENDING)
  token     String           @unique
  expiresAt DateTime         @map("expires_at")

  invitedById String @map("invited_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team      Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invitedBy User   @relation(fields: [invitedById], references: [id])

  @@index([tenantId])
  @@map("team_invitations")
}

// ─── Share Link Models ─────────────────────────────────────────

model PasswordShare {
  id            String     @id @default(cuid())
  tenantId      String     @map("tenant_id")
  tokenHash     String     @unique @map("token_hash") @db.VarChar(64)
  shareType     ShareType  @default(ENTRY_SHARE) @map("share_type")
  entryType     EntryType? @map("entry_type")
  encryptedData String     @map("encrypted_data") @db.Text
  dataIv        String     @map("data_iv") @db.VarChar(24)
  dataAuthTag   String     @map("data_auth_tag") @db.VarChar(32)
  expiresAt     DateTime   @map("expires_at")
  maxViews      Int?       @map("max_views")
  viewCount     Int        @default(0) @map("view_count")
  revokedAt     DateTime?  @map("revoked_at")
  createdById   String     @map("created_by_id")
  createdAt     DateTime   @default(now()) @map("created_at")

  // Entry share relations
  passwordEntryId     String? @map("password_entry_id")
  teamPasswordEntryId String? @map("team_password_entry_id")

  // Send-specific fields
  sendName        String? @map("send_name") @db.VarChar(200)
  sendFilename    String? @map("send_filename") @db.VarChar(255)
  sendContentType String? @map("send_content_type") @db.VarChar(100)
  sendSizeBytes   Int?    @map("send_size_bytes")
  encryptedFile   Bytes?  @map("encrypted_file")
  fileIv          String? @map("file_iv") @db.VarChar(24)
  fileAuthTag     String? @map("file_auth_tag") @db.VarChar(32)

  // Master key version used to encrypt this share's data
  masterKeyVersion Int @default(1) @map("master_key_version")

  // Share permissions (e.g., ["HIDE_PASSWORD"], empty = VIEW_ALL)
  permissions String[] @default([])

  // Optional access password protection (HMAC-peppered SHA-256 hash)
  accessPasswordHash String? @map("access_password_hash") @db.VarChar(128)

  createdBy         User               @relation(fields: [createdById], references: [id], onDelete: Cascade)
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  passwordEntry     PasswordEntry?     @relation("personalShares", fields: [passwordEntryId], references: [id], onDelete: SetNull)
  teamPasswordEntry TeamPasswordEntry? @relation("teamShares", fields: [teamPasswordEntryId], references: [id], onDelete: SetNull)
  accessLogs        ShareAccessLog[]

  @@index([passwordEntryId])
  @@index([teamPasswordEntryId])
  @@index([expiresAt])
  @@index([createdById, createdAt(sort: Desc)])
  @@index([tenantId])
  @@map("password_shares")
}

