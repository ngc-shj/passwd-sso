  waitDays     Int                   @map("wait_days")

  tokenHash      String   @unique @map("token_hash") @db.VarChar(64)
  tokenExpiresAt DateTime @map("token_expires_at") @db.Timestamptz(3)

  // ECDH key exchange fields
  keyAlgorithm            String  @default("ECDH-P256") @map("key_algorithm") @db.VarChar(32)
  granteePublicKey        String? @map("grantee_public_key") @db.Text
  ownerEphemeralPublicKey String? @map("owner_ephemeral_public_key") @db.Text
  encryptedSecretKey      String? @map("encrypted_secret_key") @db.Text
  secretKeyIv             String? @map("secret_key_iv") @db.VarChar(24)
  secretKeyAuthTag        String? @map("secret_key_auth_tag") @db.VarChar(32)
  hkdfSalt                String? @map("hkdf_salt") @db.VarChar(64)
  wrapVersion             Int     @default(1) @map("wrap_version")
  keyVersion              Int?    @map("key_version")

  // ML-KEM fields (v2 PQC hybrid, nullable until migration)
  kemCiphertext String? @map("kem_ciphertext") @db.Text
  kemPublicKey  String? @map("kem_public_key") @db.Text

  // Timestamps for state machine
  requestedAt   DateTime? @map("requested_at") @db.Timestamptz(3)
  activatedAt   DateTime? @map("activated_at") @db.Timestamptz(3)
  waitExpiresAt DateTime? @map("wait_expires_at") @db.Timestamptz(3)
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  owner          User                    @relation("emergencyGrantsAsOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  grantee        User?                   @relation("emergencyGrantsAsGrantee", fields: [granteeId], references: [id], onDelete: SetNull)
  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  granteeKeyPair EmergencyAccessKeyPair?

  @@index([ownerId, status])
  @@index([granteeId])
  @@index([tenantId])
  @@map("emergency_access_grants")
}

